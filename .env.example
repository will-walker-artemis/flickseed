# Copy this file to `.env.local` and fill in your values.
# .env.local is gitignored — never commit your TMDB key.

# Get one at https://www.themoviedb.org/settings/api (use the v3 "API Key").
VITE_TMDB_API_KEY=

# Where the data/ directory lives. These tell the app which repo to read from
# (raw.githubusercontent.com) and write to (GitHub Contents API).
VITE_GH_OWNER=
VITE_GH_REPO=
VITE_GH_BRANCH=main
